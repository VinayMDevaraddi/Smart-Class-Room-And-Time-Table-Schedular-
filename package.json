{
  "name": "smart-classroom",
  "version": "1.0.0",
  "description": "Smart Classroom and Timetable Scheduler",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node app.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^9.1.6",
    "mongoose": "^8.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
